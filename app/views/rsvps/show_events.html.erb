<div>
  <h1 class="type-serif-heading" style="font-size: var(--text-3xl); margin-bottom: var(--space-1);">Event RSVPs for <%= @guests.map(&:first_name).to_sentence %></h1>
  <p style="color: var(--color-text-secondary); margin-bottom: var(--space-8);">
    Let us know which events each guest can attend.
  </p>

  <%= form_with url: rsvp_update_path(invite_id: @invite.id, step: "events"), method: :post do |f| %>
    <% @events.each do |event| %>
      <div class="card" style="margin-bottom: var(--space-6); padding: 0; overflow: hidden; display: flex;">
        <% if event.image.present? %>
          <div style="flex: 0 0 20%; overflow: hidden; border-right: 1px solid var(--color-border);">
            <%= image_tag "events/#{event.image}", style: "width: 100%; height: 100%; object-fit: cover; display: block;", alt: event.name %>
          </div>
        <% end %>
        <div style="flex: 1; min-width: 0;">
          <div style="padding: var(--space-4);">
            <h2 style="font-family: var(--font-serif); font-size: var(--text-xl); color: var(--color-text-highlight); margin-bottom: 2px;"><%= event.name %></h2>
            <p style="font-size: var(--text-sm); font-weight: 600; color: var(--color-text-primary); margin-bottom: 1px;">
              <%= event.date&.strftime("%A, %B %d, %Y") %>
              <% if event.start_time %> at <%= event.start_time.strftime("%l:%M %p").strip %><% end %>
            </p>
            <% if event.location.present? %>
              <p style="font-size: var(--text-xs); color: var(--color-text-muted);"><%= event.location %></p>
            <% end %>
          </div>

          <div style="display: flex; align-items: center; padding: var(--space-2) var(--space-4); border-bottom: 1px solid var(--color-border); font-size: var(--text-xs); color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">
            <span style="width: 130px; flex-shrink: 0;"></span>
            <span style="flex: 1; text-align: center;">Joyfully accepts</span>
            <span style="flex: 1; text-align: center;">Regretfully declines</span>
          </div>
          <% @guests.each do |guest| %>
            <% rsvp = guest.rsvp_for(event) %>
            <div style="display: flex; align-items: center; padding: var(--space-3) var(--space-4);">
              <span style="width: 130px; flex-shrink: 0; font-weight: 500; font-size: var(--text-sm);"><%= guest.first_name %> <%= guest.last_name %></span>
              <label class="form-check form-check-sm" style="flex: 1; display: flex; justify-content: center;">
                <%= radio_button_tag "rsvps[#{event.id}][#{guest.id}][attending]", "true", rsvp&.attending == true %>
              </label>
              <label class="form-check form-check-sm" style="flex: 1; display: flex; justify-content: center;">
                <%= radio_button_tag "rsvps[#{event.id}][#{guest.id}][attending]", "false", rsvp&.attending == false %>
              </label>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="flex justify-between items-center" style="margin-top: var(--space-6);">
      <%= link_to "← Back to Guests", rsvp_show_path(invite_id: @invite.id), class: "btn btn-outline" %>
      <%= f.submit "Next: Leave a Note", class: "btn btn-highlight btn-lg" %>
    </div>
  <% end %>
</div>
