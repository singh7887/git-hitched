<div data-controller="appear">
  <h1 class="type-display-punjabi text-center animate-fade-in-up" style="margin-bottom: var(--space-4);">Weekend Events</h1>
  <p class="text-center animate-fade-in-up delay-1" style="color: var(--color-text-secondary); margin-bottom: var(--space-12);">November 25–28, 2026 · Anaheim, California</p>

  <div class="space-y-8">
    <% @events.each_with_index do |event, i| %>
      <% is_thanksgiving = event.name == "Thanksgiving Day" %>
      <% is_ceremony = event.name == "Anand Karaj" %>
      <% delay_class = i == 0 ? "" : "appear-delay-#{[i, 3].min}" %>

      <% if is_thanksgiving %>
        <%# Thanksgiving — informational only, no RSVP %>
        <div class="card card-event-free appear <%= delay_class %>">
          <div class="card-body">
            <div style="display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-3);">
              <p class="type-serif-small" style="color: var(--color-text-muted); margin: 0;"><%= event.subtitle %></p>
              <span style="font-size: var(--text-xs); font-weight: 600; letter-spacing: 0.05em; color: var(--color-text-muted); background: var(--color-surface); border: 1px solid var(--color-border); padding: 2px 8px; border-radius: 999px;">FREE DAY</span>
            </div>
            <h2 class="card-title" style="margin-bottom: var(--space-3);"><%= event.name %></h2>
            <p style="color: var(--color-text-secondary);"><%= event.description %></p>
          </div>
        </div>

      <% elsif is_ceremony %>
        <%# Anand Karaj — full-width feature card with timeline %>
        <section class="card card-event-ceremony appear <%= delay_class %>" style="overflow: hidden;">
          <% if event.image.present? %>
            <div style="height: 360px; overflow: hidden; border-bottom: var(--border-thin);">
              <%= image_tag "events/#{event.image}", style: "width: 100%; height: 100%; object-fit: cover; object-position: center 60%; display: block;", alt: event.location %>
            </div>
          <% end %>
          <div class="card-body" style="padding: var(--space-8);">
            <p class="type-serif-small" style="color: var(--color-text-muted); margin-bottom: var(--space-2);"><%= event.subtitle %></p>
            <h2 class="card-title" style="margin-bottom: var(--space-6);"><%= event.name %></h2>

            <div style="display: flex; gap: var(--space-8); flex-wrap: wrap; margin-bottom: var(--space-6);">
              <div>
                <p style="margin-bottom: var(--space-1);">
                  <strong>Location:</strong>
                  <% if event.location_url.present? && event.location_url != "#" %>
                    <a href="<%= event.location_url %>" target="_blank" rel="noopener" style="color: var(--color-accent);"><%= event.location %></a>
                  <% else %>
                    <%= event.location %>
                  <% end %>
                </p>
                <% if event.address.present? %>
                  <p style="margin-bottom: var(--space-1);">
                    <% if event.maps_url.present? && event.maps_url != "#" %>
                      <a href="<%= event.maps_url %>" target="_blank" rel="noopener" style="color: var(--color-text-muted);"><%= event.address %></a>
                    <% else %>
                      <span style="color: var(--color-text-muted);"><%= event.address %></span>
                    <% end %>
                  </p>
                <% end %>
                <% if event.attire.present? %>
                  <p><strong>Attire:</strong> <%= event.attire %></p>
                <% end %>
              </div>
            </div>

            <%# Day-of timeline %>
            <div style="margin-bottom: var(--space-6);">
              <h3 style="font-size: var(--text-sm); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-text-muted); margin-bottom: var(--space-4);">Day-of Schedule</h3>
              <div style="display: grid; gap: var(--space-2);">
                <% [
                  ["8:00 AM", "Depart JW Marriott (shuttle available)"],
                  ["8:30 AM", "Barat arrives at Gurudwara"],
                  ["9:00 AM", "Milni — families formally greet each other"],
                  ["9:00–10:00 AM", "Tea and snacks"],
                  ["10:00 AM", "Proceed to Darbar Hall"],
                  ["10:00–12:00 PM", "Anand Karaj"],
                  ["12:00 PM", "Langar — vegetarian community meal in tent"],
                  ["1:30 PM", "Doli — bride's departure ceremony"]
                ].each do |time, detail| %>
                  <div style="display: grid; grid-template-columns: 10rem 1fr; gap: var(--space-3); padding: var(--space-2) 0; border-bottom: 1px solid var(--color-border-light);">
                    <span style="font-size: var(--text-sm); font-weight: 600; color: var(--color-text-muted); white-space: nowrap;"><%= time %></span>
                    <span style="font-size: var(--text-sm); color: var(--color-text-secondary);"><%= detail %></span>
                  </div>
                <% end %>
              </div>
            </div>

            <p style="color: var(--color-text-secondary); margin-bottom: var(--space-4);"><%= event.description %></p>

            <% if event.attire_description.present? %>
              <div style="background: var(--color-gold-bg); border-left: 3px solid var(--color-gold); padding: var(--space-4); border-radius: 0 var(--radius-sm) var(--radius-sm) 0;">
                <p style="font-size: var(--text-sm); font-weight: 600; margin-bottom: var(--space-1); color: var(--color-text-highlight);">Gurudwara Dress Code</p>
                <p style="font-size: var(--text-sm); color: var(--color-text-secondary);"><%= event.attire_description %></p>
              </div>
            <% end %>
          </div>
        </section>

      <% else %>
        <%# Standard event — alternating image/content layout %>
        <% image_left = i.even? %>
        <% is_mehndi     = event.name.downcase.include?("mehndi") || event.name.downcase.include?("mehendi") %>
        <% is_jago       = event.name.downcase.include?("jago") %>
        <% is_reception  = event.name.downcase.include?("reception") || event.name.downcase.include?("baraat") %>
        <% event_card_class = if is_mehndi then "card-event-mehndi"
                               elsif is_jago then "card-event-jago"
                               elsif is_reception then "card-event-reception"
                               else "card-event-ceremony" end %>
        <div class="appear <%= delay_class %>" style="display: flex; gap: var(--space-4); align-items: stretch; flex-wrap: wrap;">
          <% if event.image.present? && image_left %>
            <div class="card" style="padding: 0; overflow: hidden; flex: 0 0 40%; min-height: 360px;">
              <%= image_tag "events/#{event.image}", style: "width: 100%; height: 100%; object-fit: cover; object-position: center 50%; display: block;", alt: event.name %>
            </div>
          <% end %>

          <section class="card <%= event_card_class %>" style="flex: 1; min-width: 280px;">
            <div class="card-body">
              <p class="type-serif-small" style="color: var(--color-text-muted); margin-bottom: var(--space-2);"><%= event.subtitle %></p>
              <h2 class="card-title" style="margin-bottom: var(--space-4);"><%= event.name %></h2>

              <div style="margin-bottom: var(--space-4);">
                <% if event.time_description.present? %>
                  <p style="margin-bottom: var(--space-1);"><strong>Time:</strong> <%= event.time_description %></p>
                <% end %>
                <% if event.location.present? %>
                  <p style="margin-bottom: var(--space-1);">
                    <strong>Location:</strong>
                    <% if event.location_url.present? && event.location_url != "#" %>
                      <a href="<%= event.location_url %>" target="_blank" rel="noopener" style="color: var(--color-accent);"><%= event.location %></a>
                    <% else %>
                      <%= event.location %>
                    <% end %>
                  </p>
                <% end %>
                <% if event.address.present? %>
                  <p style="margin-bottom: var(--space-1);">
                    <% if event.maps_url.present? && event.maps_url != "#" %>
                      <a href="<%= event.maps_url %>" target="_blank" rel="noopener" style="color: var(--color-text-muted); font-size: var(--text-sm);"><%= event.address %></a>
                    <% else %>
                      <span style="color: var(--color-text-muted); font-size: var(--text-sm);"><%= event.address %></span>
                    <% end %>
                  </p>
                <% end %>
                <% if event.attire.present? %>
                  <p><strong>Attire:</strong> <%= event.attire %></p>
                <% end %>
              </div>

              <% if event.attire_description.present? %>
                <p style="color: var(--color-text-secondary); font-style: italic; margin-bottom: var(--space-3); font-size: var(--text-sm);"><%= event.attire_description %></p>
              <% end %>
              <p style="color: var(--color-text-secondary);"><%= event.description %></p>
            </div>
          </section>

          <% if event.image.present? && !image_left %>
            <div class="card" style="padding: 0; overflow: hidden; flex: 0 0 40%; min-height: 360px;">
              <%= image_tag "events/#{event.image}", style: "width: 100%; height: 100%; object-fit: cover; object-position: center 50%; display: block;", alt: event.name %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>
