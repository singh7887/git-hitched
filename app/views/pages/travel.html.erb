<div data-controller="appear">
  <h1 class="type-serif-heading text-center animate-fade-in-up" style="font-size: var(--text-3xl); margin-bottom: var(--space-4);">Travel</h1>
  <p class="text-center animate-fade-in-up delay-1" style="color: var(--color-text-secondary); margin-bottom: var(--space-12);">Getting to the venue</p>

  <div class="space-y-8">
    <!-- Getting There -->
    <div class="appear" style="margin-bottom: var(--space-4);">
      <p style="color: var(--color-text-secondary);">
        Château de Flapjack is located in the heart of the countryside, just outside Buttersville.
      </p>
    </div>
    <section class="card appear" style="overflow: hidden; padding: 0; border-radius: var(--radius-md);">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d92456.00!2d5.2231091!3d43.536136!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12c98da304b91259%3A0x5cb953bec8b688a3!2sAix-en-Provence%2C%20France!5e0!3m2!1sen!2sus!4v1"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade">
      </iframe>
    </section>
    <!-- Flights -->
    <section class="card appear">
      <div class="card-body">
        <h2 class="card-title" style="margin-bottom: var(--space-4);">Flights</h2>

        <div style="margin-bottom: var(--space-6);">
          <h3 style="font-weight: 600; margin-bottom: var(--space-1);">Nearest Major Airport (ABC)</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-1);">Approx. 1 hour from Château de Flapjack</p>
          <p style="color: var(--color-text-secondary);">The most convenient international hub with extensive connections.</p>
        </div>

        <div style="margin-bottom: var(--space-6);">
          <h3 style="font-weight: 600; margin-bottom: var(--space-1);">Regional Airport (XYZ)</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-1);">Approx. 45 minutes from the venue</p>
          <p style="color: var(--color-text-secondary);">Ideal for domestic arrivals.</p>
        </div>

        <div>
          <h3 style="font-weight: 600; margin-bottom: var(--space-1);">Alternate Airport (DEF)</h3>
          <p style="color: var(--color-text-muted); margin-bottom: var(--space-1);">Approx. 2.5 hours from Château de Flapjack</p>
          <p style="color: var(--color-text-secondary);">A good option if you'd like to combine the wedding with a longer trip.</p>
        </div>
      </div>
    </section>

    <!-- Wedding Day Transport -->
    <section class="card appear">
      <div class="card-body">
        <h2 class="card-title" style="margin-bottom: var(--space-4);">Wedding Day Transport</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: var(--space-4);">
          On the wedding day, a dedicated transfer service will operate from a select number of pick-up points to the ceremony at Château de Flapjack.
        </p>
        <p style="color: var(--color-text-secondary); margin-bottom: var(--space-4);">
          Following the aperitif, guests will be transported to the venue where the dinner and evening celebration will take place. At the conclusion of the night, return transfers will be provided to designated drop-off points near the main accommodation areas.
        </p>
        <p style="color: var(--color-text-secondary); font-style: italic;">
          Please indicate in your RSVP if you plan to use this service.
        </p>
      </div>
    </section>

    <!-- Rental Car -->
    <section class="card appear">
      <div class="card-body">
        <h2 class="card-title" style="margin-bottom: var(--space-4);">Rental Car</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: var(--space-4);">
          For guests wishing to explore the region independently, rental cars are readily available at nearby airports.
        </p>
        <p style="color: var(--color-text-secondary);">
          The surrounding area is best experienced at a relaxed pace, and a car offers complete freedom to explore.
        </p>
      </div>
    </section>

    <!-- Travel Notes -->
    <section class="card appear">
      <div class="card-body">
        <h2 class="card-title" style="margin-bottom: var(--space-4);">Travel Notes</h2>
        <ul style="color: var(--color-text-secondary); list-style: disc; padding-left: var(--space-6);">
          <li style="margin-bottom: var(--space-2);">September weather is typically warm and pleasant — perfect for an outdoor celebration.</li>
          <li style="margin-bottom: var(--space-2);">Please ensure your travel documents are valid and up to date.</li>
          <li>Rideshare services can be limited in rural areas; taxis, private transfers or rental cars are recommended.</li>
        </ul>
      </div>
    </section>
  </div>
</div>
