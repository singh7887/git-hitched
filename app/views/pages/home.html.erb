<div class="text-center py-5">
  <p class="type-serif-small animate-fade-in-up" style="margin-bottom: var(--space-8); letter-spacing: 0.1em;">YOU ARE INVITED TO CELEBRATE THE WEDDING OF</p>

  <h1 class="type-script animate-fade-in-up delay-2" style="margin-bottom: var(--space-8);">
    <%= WEDDING[:partner_1] %><br>
    <span style="font-size: 0.5em; font-style: italic;">&</span><br>
    <%= WEDDING[:partner_2] %>
  </h1>

  <div class="divider divider-animated divider-colored animate-fade-in delay-4">a celebration of love</div>

  <div class="animate-fade-in-up delay-4" style="margin-bottom: var(--space-8);">
    <div data-controller="carousel" style="position: relative; max-width: 32rem; margin: 0 auto;">

      <div data-carousel-target="slide" class="photo-card" style="border-radius: var(--radius-lg); overflow: hidden; height: 420px;">
        <%= image_tag "couple/retro-13.jpg", style: "width: 100%; height: 100%; object-fit: cover; object-position: center;", alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}" %>
        <div class="photo-overlay-caption">
          <span style="font-family: var(--font-script); font-size: var(--text-2xl); color: #fff;">
            <%= WEDDING[:partner_1] %> & <%= WEDDING[:partner_2] %>
          </span>
        </div>
      </div>

      <div data-carousel-target="slide" class="photo-card" style="border-radius: var(--radius-lg); overflow: hidden; height: 420px; display: none;">
        <%= image_tag "couple/retro-31.jpg", style: "width: 100%; height: 100%; object-fit: cover; object-position: center;", alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}" %>
      </div>

      <div data-carousel-target="slide" class="photo-card" style="border-radius: var(--radius-lg); overflow: hidden; height: 420px; display: none;">
        <%= image_tag "couple/retro-149.jpg", style: "width: 100%; height: 100%; object-fit: cover; object-position: center;", alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}" %>
      </div>

      <div data-carousel-target="slide" class="photo-card" style="border-radius: var(--radius-lg); overflow: hidden; height: 420px; display: none;">
        <%= image_tag "couple/retro-174.jpg", style: "width: 100%; height: 100%; object-fit: cover; object-position: center;", alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}" %>
      </div>

      <div data-carousel-target="slide" class="photo-card" style="border-radius: var(--radius-lg); overflow: hidden; height: 420px; display: none;">
        <%= image_tag "couple/mangni-20.jpg", style: "width: 100%; height: 100%; object-fit: cover; object-position: center;", alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}" %>
      </div>

      <button data-action="carousel#prev" class="carousel-btn carousel-btn-prev" aria-label="Previous photo">&#8249;</button>
      <button data-action="carousel#next" class="carousel-btn carousel-btn-next" aria-label="Next photo">&#8250;</button>
      <div data-carousel-target="counter" class="carousel-counter"></div>
    </div>
  </div>

  <p class="type-serif-small animate-fade-in-up delay-5" style="margin-bottom: var(--space-2); letter-spacing: 0.05em;">NOVEMBER 25–28, 2026</p>
  <p class="animate-fade-in-up delay-5" style="font-size: var(--text-xl); color: var(--color-text-secondary); margin-bottom: var(--space-6);">Anaheim, California</p>

  <p class="animate-fade-in-up delay-6" style="font-size: var(--text-lg); color: var(--color-text-secondary); margin-bottom: var(--space-1);">JW Marriott Anaheim Resort</p>
  <p class="animate-fade-in-up delay-6" style="font-size: var(--text-base); color: var(--color-text-muted); margin-bottom: var(--space-8);">& Singh Sabha Gurudwara, Buena Park</p>

  <% if page_enabled?(:rsvp) %>
    <%= link_to "RSVP", rsvp_path, class: "btn btn-highlight btn-lg animate-scale-in delay-8" %>
  <% else %>
    <div class="card animate-fade-in-up delay-8" style="max-width: 32rem; margin: 0 auto;">
      <p style="font-size: var(--text-lg); color: var(--color-text-secondary); line-height: 1.6;">
        We'll be updating this site with more details and an RSVP form as the date approaches. In the meantime, check out the <strong><%= link_to "Events", events_path %></strong>, <strong><%= link_to "Travel", travel_path %></strong>, and <strong><%= link_to "Stay", stay_path %></strong> pages to start planning your trip.
      </p>
    </div>
  <% end %>

  <div class="divider divider-colored animate-fade-in" style="margin-top: var(--space-12);">more moments</div>

  <div data-controller="appear" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: var(--space-3); margin-top: var(--space-6);">
    <div class="photo-card appear-scale appear-delay-1" style="height: 180px; border-radius: var(--radius-md); overflow: hidden;">
      <%= image_tag "couple/retro-110.jpg", style: "width: 100%; height: 100%; object-fit: cover;", alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}" %>
    </div>
    <div class="photo-card appear-scale appear-delay-2" style="height: 180px; border-radius: var(--radius-md); overflow: hidden;">
      <%= image_tag "couple/mangni-115.jpg", style: "width: 100%; height: 100%; object-fit: cover;", alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}" %>
    </div>
    <div class="photo-card appear-scale appear-delay-3" style="height: 180px; border-radius: var(--radius-md); overflow: hidden;">
      <%= image_tag "couple/retro-153.jpg", style: "width: 100%; height: 100%; object-fit: cover;", alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}" %>
    </div>
  </div>
</div>
