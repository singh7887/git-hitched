<div data-controller="appear gallery">
  <div class="text-center" style="margin-bottom: var(--space-8);">
    <h1 class="type-serif-display animate-fade-in-up">Gallery</h1>
    <p class="animate-fade-in-up delay-2" style="color: var(--color-text-secondary); font-size: var(--text-lg); font-style: italic; margin-top: var(--space-4);">
      Moments from our journey
    </p>
    <div class="divider divider-colored animate-fade-in delay-4">our photos</div>
  </div>

  <div class="gallery-grid">
    <% gallery_photos = [
      { src: "couple/retro-13.jpg",   alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}", caption: "" },
      { src: "couple/mangni-20.jpg",  alt: "The Mangni",  caption: "The Mangni" },
      { src: "couple/retro-31.jpg",   alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}", caption: "" },
      { src: "couple/mangni-76.jpg",  alt: "The Mangni",  caption: "The Mangni" },
      { src: "couple/retro-32.jpg",   alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}", caption: "" },
      { src: "couple/mangni-98.jpg",  alt: "The Mangni",  caption: "The Mangni" },
      { src: "couple/retro-110.jpg",  alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}", caption: "" },
      { src: "couple/mangni-115.jpg", alt: "The Mangni",  caption: "The Mangni" },
      { src: "couple/retro-149.jpg",  alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}", caption: "" },
      { src: "couple/mangni-116.jpg", alt: "The Mangni",  caption: "The Mangni" },
      { src: "couple/retro-153.jpg",  alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}", caption: "" },
      { src: "couple/mangni-121.jpg", alt: "The Mangni",  caption: "The Mangni" },
      { src: "couple/retro-174.jpg",  alt: "#{WEDDING[:partner_1]} & #{WEDDING[:partner_2]}", caption: "" },
      { src: "couple/mangni-133.jpg", alt: "The Mangni",  caption: "The Mangni" },
      { src: "couple/mangni-138.jpg", alt: "The Mangni",  caption: "The Mangni" },
    ] %>

    <% gallery_photos.each_with_index do |photo, i| %>
      <div class="photo-card gallery-item appear-scale appear-delay-<%= [(i % 4) + 1, 6].min %>"
           data-gallery-full-src="<%= asset_path(photo[:src]) %>"
           data-gallery-alt="<%= photo[:alt] %>"
           data-gallery-caption="<%= photo[:caption] %>"
           data-action="click->gallery#open"
           style="cursor: pointer;">
        <%= image_tag photo[:src],
              style: "width: 100%; display: block;",
              alt: photo[:alt],
              loading: "lazy" %>
        <% if photo[:caption].present? %>
          <div class="gallery-item-overlay">
            <p style="font-family: var(--font-serif); font-size: var(--text-sm); color: #fff; font-style: italic;">
              <%= photo[:caption] %>
            </p>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <dialog data-gallery-target="dialog"
          data-action="click->gallery#backdropClose keydown->gallery#keydown"
          class="gallery-lightbox">
    <button data-action="gallery#close" class="gallery-lightbox-close" aria-label="Close">&times;</button>
    <img data-gallery-target="full" src="" alt="" style="max-width: 90vw; max-height: 85vh; object-fit: contain; display: block; border-radius: var(--radius-md);">
    <p data-gallery-target="caption" class="gallery-lightbox-caption"></p>
  </dialog>
</div>
