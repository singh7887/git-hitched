<!DOCTYPE html>
<html class="h-full">
  <head>
    <title>Admin &mdash; <%= WEDDING[:couple_names] %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Pinyon+Script&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "wedding", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <nav style="background: var(--color-bg-tertiary); border-bottom: 1px solid var(--color-border-light);">
      <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <span class="type-serif-heading" style="font-size: var(--text-lg);">Wedding Admin</span>
          <div class="flex gap-4 items-center">
            <%= link_to "Dashboard", admin_root_path, class: "type-serif-small" %>
            <span style="color: var(--color-text-muted);">&middot;</span>
            <%= link_to "Invites", admin_invites_path, class: "type-serif-small" %>
            <span style="color: var(--color-text-muted);">&middot;</span>
            <%= link_to "Guests", admin_guests_path, class: "type-serif-small" %>
            <span style="color: var(--color-text-muted);">&middot;</span>
            <%= link_to "Events", admin_events_path, class: "type-serif-small" %>
            <span style="color: var(--color-text-muted);">&middot;</span>
            <%= link_to "Hotel Bookings", admin_hotel_bookings_path, class: "type-serif-small" %>
            <span style="color: var(--color-text-muted);">&middot;</span>
            <%= link_to "Import CSV", admin_import_path, class: "type-serif-small" %>
          </div>
        </div>
        <%= link_to "View Site", root_path, class: "btn btn-ghost btn-sm" %>
      </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 py-8">
      <% if flash[:notice] %>
        <div class="notice"><%= flash[:notice] %></div>
      <% end %>
      <% if flash[:alert] %>
        <div class="notice-error"><%= flash[:alert] %></div>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
