<%= form_with model: [:admin, invite], class: "max-w-lg space-y-4" do |f| %>
  <% if invite.errors.any? %>
    <div class="notice-error">
      <% invite.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: "form-input" %>
  </div>

  <div class="form-group">
    <%= f.label :email, "Email (optional)", class: "form-label" %>
    <%= f.email_field :email, class: "form-input", placeholder: "Leave blank if sending the link personally" %>
  </div>

  <%= f.submit class: "btn btn-primary btn-sm" %>
  <%= link_to "Cancel", admin_invites_path, class: "btn btn-ghost btn-sm" %>
<% end %>
