<div class="flex items-center justify-between mb-6">
  <h1 class="type-serif-heading" style="font-size: var(--text-3xl);"><%= @event.name %></h1>
  <div class="flex gap-2">
    <%= link_to "Edit", edit_admin_event_path(@event), class: "btn btn-outline btn-sm" %>
    <%= button_to "Delete", admin_event_path(@event), method: :delete,
      data: { turbo_confirm: "Are you sure?" },
      class: "btn btn-danger btn-sm" %>
  </div>
</div>

<%# Event preview card — mirrors public events page layout %>
<div class="card mb-6" style="padding: 0; overflow: hidden;">
  <% if @event.image.present? %>
    <div style="height: 250px; overflow: hidden; border-bottom: var(--border-thin);">
      <%= image_tag "events/#{@event.image}", style: "width: 100%; height: 100%; object-fit: cover; object-position: center 50%; display: block;", alt: @event.name %>
    </div>
  <% end %>

  <div class="card-body" style="padding: var(--space-6);">
    <% if @event.subtitle.present? %>
      <p class="type-serif-small" style="color: var(--color-text-muted); margin-bottom: var(--space-2);"><%= @event.subtitle %></p>
    <% end %>
    <h2 class="card-title" style="margin-bottom: var(--space-4);"><%= @event.name %></h2>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-3); margin-bottom: var(--space-4);">
      <% if @event.location.present? %>
        <p>
          <strong>Location:</strong>
          <% if @event.location_url.present? %>
            <%= link_to @event.location, @event.location_url, target: "_blank", style: "color: var(--color-accent);" %>
          <% else %>
            <%= @event.location %>
          <% end %>
        </p>
      <% end %>

      <% if @event.address.present? %>
        <p>
          <% if @event.maps_url.present? %>
            <%= link_to @event.address, @event.maps_url, target: "_blank", style: "color: var(--color-text-muted);" %>
          <% else %>
            <span class="text-muted"><%= @event.address %></span>
          <% end %>
        </p>
      <% end %>

      <% if @event.time_description.present? %>
        <p><strong>Time:</strong> <%= @event.time_description %></p>
      <% elsif @event.date.present? || @event.start_time.present? %>
        <p><strong>Time:</strong> <%= @event.date&.strftime("%B %d, %Y") %> <%= @event.start_time&.strftime("%l:%M %p")&.strip %></p>
      <% end %>

      <% if @event.attire.present? %>
        <p><strong>Attire:</strong> <%= @event.attire %></p>
      <% end %>
    </div>

    <% if @event.attire_description.present? %>
      <p style="color: var(--color-text-secondary); font-style: italic; margin-bottom: var(--space-3);"><%= @event.attire_description %></p>
    <% end %>

    <% if @event.description.present? %>
      <p style="color: var(--color-text-secondary);"><%= @event.description %></p>
    <% end %>
  </div>

  <% if @event.sort_order.present? || @event.image.present? %>
    <div style="padding: var(--space-3) var(--space-6); border-top: var(--border-thin); font-size: var(--text-xs); color: var(--color-text-muted); display: flex; gap: var(--space-4);">
      <% if @event.sort_order.present? %>
        <span>Sort order: <%= @event.sort_order %></span>
      <% end %>
      <% if @event.image.present? %>
        <span>Image: <%= @event.image %></span>
      <% end %>
    </div>
  <% end %>
</div>

<%# RSVP stats %>
<div class="grid grid-cols-3 gap-4 mb-6">
  <div class="stat-card text-center" style="border-color: var(--color-success);">
    <p class="stat-value text-success"><%= @attending.size %></p>
    <p class="stat-label text-success">Attending</p>
  </div>
  <div class="stat-card text-center" style="border-color: var(--color-error);">
    <p class="stat-value text-error"><%= @declined.size %></p>
    <p class="stat-label text-error">Declined</p>
  </div>
  <div class="stat-card text-center">
    <p class="stat-value text-muted"><%= @pending.size %></p>
    <p class="stat-label">Pending</p>
  </div>
</div>

<% if @attending.any? %>
  <h2 class="type-serif-heading text-success" style="font-size: var(--text-lg); margin-bottom: var(--space-2);">Attending</h2>
  <div class="table-wrapper mb-6">
    <table>
      <tbody>
        <% @attending.each do |rsvp| %>
          <tr>
            <td><%= rsvp.guest.full_name %></td>
            <td class="text-muted"><%= rsvp.guest.household.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<% if @declined.any? %>
  <h2 class="type-serif-heading text-error" style="font-size: var(--text-lg); margin-bottom: var(--space-2);">Declined</h2>
  <div class="table-wrapper mb-6">
    <table>
      <tbody>
        <% @declined.each do |rsvp| %>
          <tr>
            <td><%= rsvp.guest.full_name %></td>
            <td class="text-muted"><%= rsvp.guest.household.name %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
