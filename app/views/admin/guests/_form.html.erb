<%= form_with model: [:admin, guest], class: "max-w-lg space-y-4" do |f| %>
  <% if guest.errors.any? %>
    <div class="notice-error">
      <% guest.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :invite_id, class: "form-label" %>
    <%= f.collection_select :invite_id, Invite.order(:name), :id, :name,
      { prompt: "Select invite" },
      class: "form-select" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div class="form-group">
      <%= f.label :first_name, class: "form-label" %>
      <%= f.text_field :first_name, class: "form-input" %>
    </div>
    <div class="form-group">
      <%= f.label :last_name, class: "form-label" %>
      <%= f.text_field :last_name, class: "form-input" %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :meal_choice, class: "form-label" %>
    <%= f.select :meal_choice, Guest.meal_choices.keys.map { |k| [k.titleize, k] },
      {},
      class: "form-select" %>
  </div>

  <div class="form-group">
    <%= f.label :dietary_notes, class: "form-label" %>
    <%= f.text_field :dietary_notes, class: "form-input" %>
  </div>

  <div class="form-check">
    <%= f.check_box :is_primary %>
    <%= f.label :is_primary, "Primary contact for invite", class: "form-check-label" %>
  </div>

  <div class="form-check">
    <%= f.check_box :is_child %>
    <%= f.label :is_child, "Child", class: "form-check-label" %>
  </div>

  <div class="form-group">
    <%= f.label :age, class: "form-label" %>
    <%= f.number_field :age, class: "form-input", min: 0, max: 17 %>
  </div>

  <div class="form-check">
    <%= f.check_box :needs_childcare %>
    <%= f.label :needs_childcare, "Needs childcare", class: "form-check-label" %>
  </div>

  <%= f.submit class: "btn btn-primary btn-sm" %>
  <%= link_to "Cancel", admin_guests_path, class: "btn btn-ghost btn-sm" %>
<% end %>
